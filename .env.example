# billax environment configuration
# Copy this to .env and update values for your deployment

# Required
DATABASE_URL=postgres://payd_app:password@localhost:5432/payd?sslmode=require

# Optional (these have sensible defaults)
APP_ENV=development
PORT=8080
LOG_LEVEL=info
RATE_LIMIT_DEFAULT=100
WEBHOOK_DELIVERY_TIMEOUT=10s
WEBHOOK_MAX_RETRIES=5
PROVIDERS_CONFIG_PATH=providers.yml
